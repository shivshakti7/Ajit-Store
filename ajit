</div>

<script>
function order(product) {
    let phone = "919031877095";
    let message = "Hello, mujhe order karna hai: " + product;
    let url = "https://wa.me/" + phone + "?text=" + encodeURIComponent(message);
    window.open(url, "_blank");
}
</script>

