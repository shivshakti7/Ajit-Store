<!DOCTYPE html>
<html>
<head>
    <title>Ajit Store</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    
    <style>
        body {font-family: Arial; margin:0; background:#f2f2f2;}
        header {background:#ff3f6c; color:white; padding:15px; text-align:center;}
        .container {display:flex; flex-wrap:wrap; justify-content:center;}
        .product {
            background:white; margin:10px; padding:10px; width:220px;
            border-radius:10px; box-shadow:0 0 10px gray; text-align:center;
        }
        img {width:100%; height:220px; border-radius:10px;}
        button {
            background:green; color:white; padding:10px; border:none;
            width:100%; border-radius:5px; margin-top:10px; cursor:pointer;
        }
    </style>
</head>

<body>

<header>
